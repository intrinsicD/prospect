{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prospect.local/schemas/wm-001-formal-binding-v4.json",
  "title": "WM-001 formal implementation binding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "experiment_id",
    "protocol",
    "sealed_at_utc",
    "source",
    "dependencies",
    "runtime",
    "environment",
    "irrelevant_control",
    "coverage_arithmetic",
    "checkpoint_implementation",
    "formal_replicate_master_seeds"
  ],
  "properties": {
    "schema": {
      "const": "prospect.world-model-lifecycle.formal-binding.v4"
    },
    "experiment_id": {
      "const": "WM-001"
    },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "sha256",
        "raw_result_schema_sha256",
        "binding_schema_sha256"
      ],
      "properties": {
        "version": {
          "const": "1.4.0"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "raw_result_schema_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "binding_schema_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "sealed_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_commit",
        "git_tree",
        "worktree_clean",
        "implementation_files",
        "test_report_file",
        "test_report_bytes",
        "test_report_sha256"
      ],
      "properties": {
        "git_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "git_tree": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "worktree_clean": {
          "const": true
        },
        "implementation_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/fileDigest"
          }
        },
        "test_report_file": {
          "$ref": "#/$defs/siblingFilename"
        },
        "test_report_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "test_report_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lockfile",
        "lockfile_sha256",
        "packages"
      ],
      "properties": {
        "lockfile": {
          "type": "string",
          "minLength": 1
        },
        "lockfile_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "packages": {
          "type": "array",
          "minItems": 7,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "version",
              "distribution_sha256"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "distribution_sha256": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "machine",
        "device",
        "accelerator",
        "deterministic_algorithms",
        "thread_count",
        "interop_thread_count",
        "cuda_runtime",
        "cuda_driver",
        "cublas_workspace_config"
      ],
      "properties": {
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "machine": {
          "type": "string",
          "minLength": 1
        },
        "device": {
          "enum": [
            "cpu",
            "cuda",
            "mps"
          ]
        },
        "accelerator": {
          "type": [
            "string",
            "null"
          ]
        },
        "deterministic_algorithms": {
          "const": true
        },
        "thread_count": {
          "type": "integer",
          "minimum": 1
        },
        "interop_thread_count": {
          "type": "integer",
          "minimum": 1
        },
        "cuda_runtime": {
          "type": [
            "string",
            "null"
          ]
        },
        "cuda_driver": {
          "type": [
            "string",
            "null"
          ]
        },
        "cublas_workspace_config": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "device": {
                "const": "cuda"
              }
            }
          },
          "then": {
            "properties": {
              "cublas_workspace_config": {
                "const": ":4096:8"
              }
            }
          },
          "else": {
            "properties": {
              "cublas_workspace_config": {
                "const": null
              }
            }
          }
        }
      ]
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "wrapper_source_sha256",
        "installed_distribution_sha256",
        "conformance_report_file",
        "conformance_report_bytes",
        "conformance_report_sha256"
      ],
      "properties": {
        "id": {
          "const": "Pendulum-v1"
        },
        "wrapper_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "installed_distribution_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "conformance_report_file": {
          "$ref": "#/$defs/siblingFilename"
        },
        "conformance_report_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "conformance_report_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "irrelevant_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_id",
        "source_sha256",
        "conformance_report_file",
        "conformance_report_bytes",
        "conformance_report_sha256"
      ],
      "properties": {
        "id": {
          "const": "independent_phase_oscillator"
        },
        "source_id": {
          "const": "prospect:IndependentPhaseOscillator-v1"
        },
        "source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "conformance_report_file": {
          "$ref": "#/$defs/siblingFilename"
        },
        "conformance_report_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "conformance_report_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "coverage_arithmetic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantics_id",
        "python_executable",
        "python_implementation",
        "python_version",
        "platform",
        "machine",
        "producer_source_sha256",
        "auditor_source_sha256",
        "formal_test_report_sha256",
        "conformance_report_file",
        "conformance_report_bytes",
        "conformance_report_sha256"
      ],
      "properties": {
        "semantics_id": {
          "const": "wm001-mixture-pit-binary64-count-v1"
        },
        "python_executable": {
          "type": "string",
          "minLength": 1
        },
        "python_implementation": {
          "const": "CPython"
        },
        "python_version": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "machine": {
          "type": "string",
          "minLength": 1
        },
        "producer_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "auditor_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "formal_test_report_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "conformance_report_file": {
          "$ref": "#/$defs/siblingFilename"
        },
        "conformance_report_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "conformance_report_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "checkpoint_implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "serializer_source_sha256",
        "manifest_schema_sha256",
        "component_ids"
      ],
      "properties": {
        "serializer_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "manifest_schema_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "component_ids": {
          "const": [
            "world_model",
            "optimizer",
            "model_version_ledger",
            "experience_store",
            "replay_index",
            "replay_sampling_history",
            "update_receipts",
            "agent_runtime",
            "scaling_configuration",
            "python_rng",
            "numpy_rng",
            "torch_cpu_rng",
            "torch_accelerator_rng",
            "collection_rng",
            "planner_rng"
          ]
        }
      }
    },
    "formal_replicate_master_seeds": {
      "const": [
        339970590,
        474769515,
        550273937,
        438984650,
        2732731971,
        2253809848,
        2206960337,
        3506881479
      ]
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "siblingFilename": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^/\\\\]+$"
    },
    "fileDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
