{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prospect.local/schemas/wm-001-raw-result-v4.json",
  "title": "WM-001 raw evidence and derived result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "experiment_id",
    "protocol_version",
    "protocol_sha256",
    "lane",
    "claim_eligible",
    "formal_binding_sha256",
    "started_at_utc",
    "completed_at_utc",
    "execution",
    "replicates",
    "aggregate_metrics",
    "gate_results",
    "limitations"
  ],
  "properties": {
    "schema": {
      "const": "prospect.world-model-lifecycle.raw-result.v4"
    },
    "experiment_id": {
      "const": "WM-001"
    },
    "protocol_version": {
      "const": "1.4.0"
    },
    "protocol_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "lane": {
      "enum": [
        "development",
        "formal"
      ]
    },
    "claim_eligible": {
      "type": "boolean"
    },
    "formal_binding_sha256": {
      "oneOf": [
        {
          "$ref": "#/$defs/sha256"
        },
        {
          "type": "null"
        }
      ]
    },
    "started_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_commit",
        "git_tree",
        "worktree_clean",
        "dependency_lock_sha256",
        "platform",
        "device",
        "deterministic_algorithms",
        "launcher_process_id",
        "formal_launch_file",
        "formal_launch_sha256",
        "resource_telemetry"
      ],
      "properties": {
        "git_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "git_tree": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "worktree_clean": {
          "type": "boolean"
        },
        "dependency_lock_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "device": {
          "enum": [
            "cpu",
            "cuda",
            "mps"
          ]
        },
        "deterministic_algorithms": {
          "type": "boolean"
        },
        "launcher_process_id": {
          "type": "integer",
          "minimum": 1
        },
        "formal_launch_file": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "formal-launch.json",
            null
          ]
        },
        "formal_launch_sha256": {
          "anyOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "resource_telemetry": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "integer",
              "string",
              "boolean",
              "null"
            ]
          }
        }
      }
    },
    "replicates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/replicate"
      }
    },
    "aggregate_metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/aggregateMetric"
      }
    },
    "gate_results": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/gateResult"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lane": {
            "const": "formal"
          }
        }
      },
      "then": {
        "properties": {
          "claim_eligible": {
            "const": true
          },
          "formal_binding_sha256": {
            "$ref": "#/$defs/sha256"
          },
          "execution": {
            "properties": {
              "formal_launch_file": {
                "const": "formal-launch.json"
              },
              "formal_launch_sha256": {
                "$ref": "#/$defs/sha256"
              }
            }
          },
          "replicates": {
            "minItems": 8,
            "maxItems": 8,
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/replicate"
                },
                {
                  "properties": {
                    "derived_seeds": {
                      "minItems": 21,
                      "maxItems": 21
                    },
                    "episodes": {
                      "minItems": 496,
                      "maxItems": 496
                    },
                    "transitions": {
                      "minItems": 99200,
                      "maxItems": 99200
                    },
                    "updates": {
                      "minItems": 6,
                      "maxItems": 6
                    },
                    "optimizer_batch_manifests": {
                      "minItems": 5,
                      "maxItems": 5
                    },
                    "predictive_metrics": {
                      "minItems": 12,
                      "maxItems": 12
                    },
                    "policy_runs": {
                      "minItems": 20,
                      "maxItems": 20
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "else": {
        "properties": {
          "claim_eligible": {
            "const": false
          },
          "execution": {
            "properties": {
              "formal_launch_file": {
                "const": null
              },
              "formal_launch_sha256": {
                "const": null
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "physicalObservation": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "number"
      }
    },
    "digestRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "media_type",
        "bytes",
        "sha256",
        "filename",
        "phase"
      ],
      "properties": {
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "phase": {
          "enum": [
            "train_a",
            "train_b_replay",
            "train_b_naive",
            "train_a_corrupted",
            "train_a_irrelevant"
          ]
        }
      }
    },
    "fileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "media_type",
        "bytes",
        "sha256",
        "filename"
      ],
      "properties": {
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        }
      }
    },
    "seedNamespace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespace",
        "values"
      ],
      "properties": {
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "values": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          }
        }
      }
    },
    "episode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "episode_id",
        "run_id",
        "task_id",
        "split",
        "condition",
        "checkpoint_id",
        "reset_seed",
        "process_id",
        "model_version",
        "parameter_sha256",
        "learning_allowed",
        "replay_writes_allowed",
        "environment_steps",
        "return",
        "started_at_utc",
        "completed_at_utc",
        "action_trace_sha256",
        "transition_ids"
      ],
      "properties": {
        "episode_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "enum": [
            "pendulum_normal_torque",
            "pendulum_reversed_torque",
            "independent_phase_oscillator"
          ]
        },
        "split": {
          "enum": [
            "collect_a",
            "predictive_validation_a",
            "behavior_evaluation_a",
            "collect_b",
            "collect_irrelevant",
            "predictive_validation_irrelevant",
            "predictive_validation_b",
            "behavior_evaluation_b"
          ]
        },
        "condition": {
          "enum": [
            "collection_random",
            "validation_random",
            "cold",
            "after_a",
            "frozen",
            "corrupted",
            "irrelevant",
            "after_b_replay",
            "after_b_naive",
            "random",
            "oracle"
          ]
        },
        "checkpoint_id": {
          "enum": [
            "cold",
            "after_a",
            "frozen",
            "corrupted",
            "irrelevant",
            "after_b_replay",
            "after_b_naive",
            "random",
            "oracle"
          ]
        },
        "reset_seed": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        "process_id": {
          "type": "integer",
          "minimum": 1
        },
        "model_version": {
          "type": "string",
          "minLength": 1
        },
        "parameter_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "learning_allowed": {
          "type": "boolean"
        },
        "replay_writes_allowed": {
          "type": "boolean"
        },
        "environment_steps": {
          "const": 200
        },
        "return": {
          "type": "number"
        },
        "started_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "action_trace_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "transition_ids": {
          "type": "array",
          "minItems": 200,
          "maxItems": 200,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transition_id",
        "run_id",
        "episode_id",
        "task_id",
        "task_context",
        "split",
        "step_index",
        "real_or_imagined",
        "pre_observation_id",
        "decision_id",
        "executed_action_id",
        "next_observation_id",
        "model_version_at_action",
        "parameter_sha256_at_action",
        "pre_observation",
        "intended_action",
        "applied_action",
        "next_observation",
        "reward",
        "terminated",
        "truncated",
        "scaled_target",
        "target_sha256"
      ],
      "properties": {
        "transition_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "episode_id": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "enum": [
            "pendulum_normal_torque",
            "pendulum_reversed_torque",
            "independent_phase_oscillator"
          ]
        },
        "task_context": {
          "enum": [
            0.0,
            1.0,
            2.0
          ]
        },
        "split": {
          "enum": [
            "collect_a",
            "predictive_validation_a",
            "behavior_evaluation_a",
            "collect_b",
            "collect_irrelevant",
            "predictive_validation_irrelevant",
            "predictive_validation_b",
            "behavior_evaluation_b"
          ]
        },
        "step_index": {
          "type": "integer",
          "minimum": 0,
          "maximum": 199
        },
        "real_or_imagined": {
          "const": "real"
        },
        "pre_observation_id": {
          "type": "string",
          "minLength": 1
        },
        "decision_id": {
          "type": "string",
          "minLength": 1
        },
        "executed_action_id": {
          "type": "string",
          "minLength": 1
        },
        "next_observation_id": {
          "type": "string",
          "minLength": 1
        },
        "model_version_at_action": {
          "type": "string",
          "minLength": 1
        },
        "parameter_sha256_at_action": {
          "$ref": "#/$defs/sha256"
        },
        "pre_observation": {
          "$ref": "#/$defs/physicalObservation"
        },
        "intended_action": {
          "type": "number",
          "minimum": -2.0,
          "maximum": 2.0
        },
        "applied_action": {
          "type": "number",
          "minimum": -2.0,
          "maximum": 2.0
        },
        "next_observation": {
          "$ref": "#/$defs/physicalObservation"
        },
        "reward": {
          "type": "number"
        },
        "terminated": {
          "type": "boolean"
        },
        "truncated": {
          "type": "boolean"
        },
        "scaled_target": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "number"
          }
        },
        "target_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "phase",
        "status",
        "predecessor_parameter_sha256",
        "candidate_parameter_sha256",
        "committed_parameter_sha256",
        "predecessor_model_version",
        "committed_model_version",
        "eligible_splits",
        "eligible_transition_count",
        "eligible_transition_ids",
        "consumed_sample_count",
        "consumed_multiset_sha256",
        "sampling_manifest_sha256",
        "target_permutation_sha256",
        "target_permutation_file",
        "optimizer_steps",
        "live_state_before_sha256",
        "live_state_after_sha256"
      ],
      "properties": {
        "receipt_id": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "enum": [
            "train_a",
            "train_b_replay",
            "train_b_naive",
            "train_a_corrupted",
            "train_a_irrelevant",
            "rejected_update_probe"
          ]
        },
        "status": {
          "enum": [
            "committed",
            "rejected"
          ]
        },
        "predecessor_parameter_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "candidate_parameter_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "committed_parameter_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "predecessor_model_version": {
          "type": "string",
          "minLength": 1
        },
        "committed_model_version": {
          "type": "string",
          "minLength": 1
        },
        "eligible_splits": {
          "type": "array",
          "items": {
            "enum": [
              "collect_a",
              "collect_b",
              "collect_irrelevant"
            ]
          }
        },
        "eligible_transition_count": {
          "type": "integer",
          "minimum": 0
        },
        "eligible_transition_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "consumed_sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "consumed_multiset_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "sampling_manifest_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "target_permutation_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "target_permutation_file": {
          "oneOf": [
            {
              "$ref": "#/$defs/fileRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "optimizer_steps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2000
        },
        "live_state_before_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "live_state_after_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "full_state_before_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "full_state_after_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "full_state_before_file": {
          "$ref": "#/$defs/fileRef"
        },
        "full_state_after_file": {
          "$ref": "#/$defs/fileRef"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "phase": {
                "const": "rejected_update_probe"
              }
            },
            "required": [
              "phase"
            ]
          },
          "then": {
            "required": [
              "full_state_before_sha256",
              "full_state_after_sha256",
              "full_state_before_file",
              "full_state_after_file"
            ]
          }
        }
      ]
    },
    "predictiveMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "condition",
        "checkpoint_id",
        "model_version",
        "parameter_sha256",
        "live_state_sha256",
        "split",
        "transition_count",
        "mixture_nll_nats_per_target_dimension",
        "normalized_rmse",
        "coverage_semantics",
        "interval_90_covered_target_count",
        "coverage_target_count",
        "interval_90_coverage",
        "prediction_rows_sha256",
        "prediction_evidence_file",
        "prediction_evidence_bytes"
      ],
      "properties": {
        "task_id": {
          "enum": [
            "pendulum_normal_torque",
            "pendulum_reversed_torque",
            "independent_phase_oscillator"
          ]
        },
        "condition": {
          "enum": [
            "cold",
            "after_a",
            "frozen",
            "corrupted",
            "irrelevant",
            "after_b_replay",
            "after_b_naive"
          ]
        },
        "checkpoint_id": {
          "enum": [
            "cold",
            "after_a",
            "frozen",
            "corrupted",
            "irrelevant",
            "after_b_replay",
            "after_b_naive"
          ]
        },
        "model_version": {
          "type": "string",
          "minLength": 1
        },
        "parameter_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "live_state_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "split": {
          "enum": [
            "predictive_validation_a",
            "predictive_validation_irrelevant",
            "predictive_validation_b"
          ]
        },
        "transition_count": {
          "const": 1600
        },
        "mixture_nll_nats_per_target_dimension": {
          "type": "number"
        },
        "normalized_rmse": {
          "type": "number",
          "minimum": 0.0
        },
        "coverage_semantics": {
          "const": "wm001-mixture-pit-binary64-count-v1"
        },
        "interval_90_covered_target_count": {
          "type": "integer",
          "minimum": 0
        },
        "coverage_target_count": {
          "type": "integer",
          "minimum": 1
        },
        "interval_90_coverage": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "prediction_rows_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "prediction_evidence_file": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "prediction_evidence_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "policyRun": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "task_id",
        "split",
        "condition",
        "checkpoint_id",
        "controller_kind",
        "controller_version",
        "seed_namespace",
        "seed_index",
        "seed",
        "reset_seeds",
        "episode_ids",
        "rng_start_sha256",
        "rng_end_sha256",
        "action_count",
        "action_trace_sha256",
        "planner_budget"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "enum": [
            "pendulum_normal_torque",
            "pendulum_reversed_torque",
            "independent_phase_oscillator"
          ]
        },
        "split": {
          "enum": [
            "collect_a",
            "predictive_validation_a",
            "behavior_evaluation_a",
            "collect_b",
            "collect_irrelevant",
            "predictive_validation_irrelevant",
            "predictive_validation_b",
            "behavior_evaluation_b"
          ]
        },
        "condition": {
          "enum": [
            "collection_random",
            "validation_random",
            "cold",
            "after_a",
            "frozen",
            "corrupted",
            "irrelevant",
            "after_b_replay",
            "after_b_naive",
            "random",
            "oracle"
          ]
        },
        "checkpoint_id": {
          "enum": [
            "cold",
            "after_a",
            "frozen",
            "corrupted",
            "irrelevant",
            "after_b_replay",
            "after_b_naive",
            "random",
            "oracle"
          ]
        },
        "controller_kind": {
          "enum": [
            "uniform_random",
            "cem_learned",
            "cem_oracle"
          ]
        },
        "controller_version": {
          "type": "string",
          "minLength": 1
        },
        "seed_namespace": {
          "type": "string",
          "minLength": 1
        },
        "seed_index": {
          "type": "integer",
          "minimum": 0
        },
        "seed": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        "reset_seeds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967295
          }
        },
        "episode_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rng_start_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "rng_end_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "action_count": {
          "type": "integer",
          "minimum": 1
        },
        "action_trace_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "planner_budget": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "planning_horizon",
                "optim_steps",
                "num_candidates",
                "top_k"
              ],
              "properties": {
                "planning_horizon": {
                  "const": 10
                },
                "optim_steps": {
                  "const": 3
                },
                "num_candidates": {
                  "const": 64
                },
                "top_k": {
                  "const": 8
                }
              }
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "evaluatedCheckpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition",
        "model_version",
        "parameter_sha256",
        "live_state_sha256",
        "media_type",
        "bytes",
        "sha256",
        "filename"
      ],
      "properties": {
        "condition": {
          "enum": [
            "cold",
            "frozen",
            "corrupted",
            "irrelevant",
            "after_a",
            "after_b_replay",
            "after_b_naive"
          ]
        },
        "model_version": {
          "type": "string",
          "minLength": 1
        },
        "parameter_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "live_state_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "media_type": {
          "const": "application/vnd.prospect.wm001.owned-model-state"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        }
      }
    },
    "checkpointComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "component_id",
        "logical_version",
        "media_type",
        "bytes",
        "sha256",
        "predecessor_sha256"
      ],
      "properties": {
        "checkpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "component_id": {
          "type": "string",
          "minLength": 1
        },
        "logical_version": {
          "type": "string",
          "minLength": 1
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "predecessor_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "restartParity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_manifest_sha256",
        "original_process_id",
        "restored_process_id",
        "fresh_process",
        "component_hash_mismatches",
        "identity_or_lineage_mismatches",
        "prediction_max_abs_difference",
        "action_max_abs_difference",
        "episode_return_max_abs_difference",
        "live_evaluation",
        "restored_evaluation"
      ],
      "properties": {
        "checkpoint_manifest_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "original_process_id": {
          "type": "integer",
          "minimum": 1
        },
        "restored_process_id": {
          "type": "integer",
          "minimum": 1
        },
        "fresh_process": {
          "type": "boolean"
        },
        "component_hash_mismatches": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "identity_or_lineage_mismatches": {
          "type": "integer",
          "minimum": 0
        },
        "prediction_max_abs_difference": {
          "type": "number",
          "minimum": 0.0
        },
        "action_max_abs_difference": {
          "type": "number",
          "minimum": 0.0
        },
        "episode_return_max_abs_difference": {
          "type": "number",
          "minimum": 0.0
        },
        "live_evaluation": {
          "$ref": "#/$defs/fileRef"
        },
        "restored_evaluation": {
          "$ref": "#/$defs/fileRef"
        }
      }
    },
    "replicate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replicate_id",
        "master_seed",
        "derived_seeds",
        "episodes",
        "transitions",
        "updates",
        "optimizer_batch_manifests",
        "predictive_metrics",
        "policy_runs",
        "evaluated_checkpoints",
        "checkpoint_components",
        "checkpoint_archive",
        "restart_parity"
      ],
      "properties": {
        "replicate_id": {
          "type": "string",
          "minLength": 1
        },
        "master_seed": {
          "type": "integer",
          "minimum": 0
        },
        "derived_seeds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/seedNamespace"
          }
        },
        "episodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/episode"
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transition"
          }
        },
        "updates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/update"
          }
        },
        "optimizer_batch_manifests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/digestRef"
          }
        },
        "predictive_metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/predictiveMetric"
          }
        },
        "policy_runs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/policyRun"
          }
        },
        "evaluated_checkpoints": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "$ref": "#/$defs/evaluatedCheckpoint"
          }
        },
        "checkpoint_components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/checkpointComponent"
          }
        },
        "checkpoint_archive": {
          "$ref": "#/$defs/fileRef"
        },
        "restart_parity": {
          "oneOf": [
            {
              "$ref": "#/$defs/restartParity"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "aggregateMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "unit",
        "replicate_values",
        "mean",
        "ci_95_lower",
        "ci_95_upper"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "replicate_values": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "mean": {
          "type": "number"
        },
        "ci_95_lower": {
          "type": "number"
        },
        "ci_95_upper": {
          "type": "number"
        }
      }
    },
    "gateCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "observed",
        "comparator",
        "threshold",
        "passed",
        "raw_evidence_sha256"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "observed": {
          "type": [
            "number",
            "integer",
            "boolean",
            "string"
          ]
        },
        "comparator": {
          "enum": [
            "eq",
            "gt",
            "ge",
            "lt",
            "le"
          ]
        },
        "threshold": {
          "type": [
            "number",
            "integer",
            "boolean",
            "string"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "raw_evidence_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "gateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "name",
        "checks",
        "passed",
        "claim_supported",
        "stop_reason"
      ],
      "properties": {
        "gate": {
          "enum": [
            "K0",
            "K1",
            "K2",
            "K3",
            "K4",
            "K5",
            "K6",
            "K7"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gateCheck"
          }
        },
        "passed": {
          "type": "boolean"
        },
        "claim_supported": {
          "type": "boolean"
        },
        "stop_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
