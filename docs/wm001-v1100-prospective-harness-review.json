{"disposition":"accepted","experiment_id":"WM-001","findings":[{"id":"F001","resolution":"resolved","severity":"major","summary":"Development diagnostics and lifecycle outputs could share caller-selected paths, allowing diagnostic execution to poison a canonical one-shot namespace."},{"id":"F002","resolution":"resolved","severity":"major","summary":"An existing canonical development closure marker could enter a resume-shaped operator path instead of refusing before any verification or output work."},{"id":"F003","resolution":"resolved","severity":"major","summary":"Operator and preformal one-shot claims needed deterministic hidden names, durable parent-directory commits, and terminal stranded-claim behavior across initially absent namespaces."},{"id":"F004","resolution":"resolved","severity":"major","summary":"Preformal commands and logs could expose a partial canonical evidence bundle before the complete report was semantically verified."},{"id":"F005","resolution":"resolved","severity":"major","summary":"A zero-exit runtime command with malformed semantic output could leave all_pass or the generation envelope misleadingly true."},{"id":"F006","resolution":"resolved","severity":"major","summary":"The independent formal auditor retained an obsolete command-9 mode and five-input contract after the producer moved to accepted-closure evidence with seven inputs."},{"id":"F007","resolution":"resolved","severity":"major","summary":"The outer launcher originally shape-checked the formal-input receipt without independently binding its command-9 and command-10 semantic digests to the reopened canonical outputs."},{"id":"F008","resolution":"resolved","severity":"major","summary":"Formal-input preflight needed an integration test proving both substantive report and development-qualification validators compose unmocked before binding acceptance."},{"id":"F009","resolution":"resolved","severity":"minor","summary":"The Makefile and operator documentation retained stale version pointers or ambiguous verification counts after the v1.10 namespace transition."},{"id":"F010","resolution":"informational","severity":"note","summary":"The sealed scientific block, four scientific kernel sources, model, optimizer, planner, budgets, metrics, thresholds, and exclusions remain unchanged while v1.10 uses fresh masters and namespaces."},{"id":"F011","resolution":"informational","severity":"note","summary":"One reviewed wheel was installed non-editably into separate fresh QA and runtime environments; their Prospect distribution digests match, the 45-row runtime lock verifies, and CUDA is available on the RTX 3050."},{"id":"F012","resolution":"informational","severity":"note","summary":"The custody model trusts the same principal, kernel, filesystem, base interpreter, and cooperating writers and provides neither hostile-writer resistance nor external attestation."}],"implementation_files":[{"bytes":1143,"path":"Makefile","sha256":"c21ca7ea6cc4f7546e01d5b51b494f3235fbfc874b2fdfe4582be93c9eb83f07"},{"bytes":148,"path":"bench/__init__.py","sha256":"6c7b9de75c247ced5f62064f9786cf6e2f14d958bd1be6eb65c6ed69680b6942"},{"bytes":561,"path":"bench/epistemic/__init__.py","sha256":"bb77dc8aba3b32b6bc2df16a5abd9fc24b0ece2a389e814c3337a0f637a5467e"},{"bytes":44718,"path":"bench/epistemic/lifecycle.py","sha256":"3d30d947ca830a0c307f2e7f40d31bc4bef51d497f2e96d68f000fa864e3ed25"},{"bytes":30661,"path":"bench/epistemic/maturity.py","sha256":"2a81abe60f12285f66f2bcd351589de28851412f1d9df7f2003843a845a2510e"},{"bytes":13611,"path":"bench/epistemic/problem.py","sha256":"c66ae13d3e833ffd1be1562a89e0e9035d6197b95723179b930c1ca2a1059c66"},{"bytes":1097,"path":"bench/epistemic/run_maturity.py","sha256":"86ae2c3175262f559a274827c96c30212fbdb9250e3a4614f92c861b7498feb7"},{"bytes":20656,"path":"bench/epistemic/runtime_lane.py","sha256":"d8f0c7a85be786c3a813ee1f169abcbc2791a642e46fba5978f7a1140cc50387"},{"bytes":278,"path":"bench/world_model_lifecycle/SEALED_PROTOCOL.sha256","sha256":"